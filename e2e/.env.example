# Beacon2 E2E test environment configuration
# Copy this file to .env and fill in the values for your staging environment.
# Never commit the real .env file.

# ── Frontend URL (Playwright navigates here) ──────────────────────────────
BEACON2_BASE_URL=https://beacon2-staging.example.com

# ── Backend API URL (used by global-setup.js for direct API calls) ─────────
# Must be the URL the browser sees the API at (same-origin if proxied,
# or the full API URL if cross-origin).
BEACON2_API_URL=https://beacon2-api-staging.example.com

# ── System-admin credentials (to create / reset the test tenant) ──────────
# BEACON2_SYSADMIN_EMAIL is the email address of the system-admin account.
# The legacy BEACON2_SYSADMIN_USERNAME variable is also accepted as a fallback.
BEACON2_SYSADMIN_EMAIL=sysadmin@beacon2.invalid
BEACON2_SYSADMIN_PASSWORD=changeme

# ── Test tenant configuration ─────────────────────────────────────────────
# A dedicated test tenant is created (or reused) for all E2E tests.
# Use a slug that cannot clash with real u3a tenants.
BEACON2_TEST_TENANT_SLUG=e2etest
BEACON2_TEST_TENANT_NAME=E2E Test u3a

# ── Test tenant admin user ────────────────────────────────────────────────
BEACON2_TEST_ADMIN_USERNAME=testadmin
BEACON2_TEST_ADMIN_PASSWORD=TestAdmin99!
BEACON2_TEST_ADMIN_NAME=Test Administrator
BEACON2_TEST_ADMIN_EMAIL=testadmin@beacon2-e2e.invalid
